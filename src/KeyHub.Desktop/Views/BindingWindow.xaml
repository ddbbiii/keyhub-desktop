<Window x:Class="KeyHub.Desktop.Views.BindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="环境变量映射" Width="520" Height="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource CanvasBrush}">
    <Grid Margin="26"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="添加环境变量映射" FontSize="25" FontWeight="SemiBold" /><TextBlock Text="项目读取变量名，KeyHub 在启动时提供对应密钥值。" Style="{StaticResource PageSubtitle}" /></StackPanel>
        <Grid Grid.Row="1" Margin="0,22,0,18"><Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><TextBlock Text="环境变量" VerticalAlignment="Center" /><ComboBox x:Name="EnvironmentBox" Grid.Column="1" Height="36" IsEditable="True" /><TextBlock Grid.Row="1" Text="密钥" Margin="0,16,0,0" VerticalAlignment="Center" /><ComboBox x:Name="SecretBox" Grid.Row="1" Grid.Column="1" Height="36" Margin="0,12,0,0" /></Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" Click="OnCancel" /><Button Content="保存映射" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="OnSave" /></StackPanel>
    </Grid>
</Window>
