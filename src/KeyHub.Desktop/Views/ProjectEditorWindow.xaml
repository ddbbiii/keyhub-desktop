<Window x:Class="KeyHub.Desktop.Views.ProjectEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="项目" Width="650" Height="510" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource CanvasBrush}">
    <Grid Margin="26"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel><TextBlock x:Name="HeadingText" Text="新增项目" Style="{StaticResource PageTitle}" /><TextBlock Text="项目清单只声明变量名；具体密钥映射保存在本机。" Style="{StaticResource PageSubtitle}" /></StackPanel>
        <Grid Grid.Row="1" Margin="0,24,0,18"><Grid.ColumnDefinitions><ColumnDefinition Width="135" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="项目 ID" VerticalAlignment="Center" /><TextBox x:Name="IdBox" Grid.Column="1" Grid.ColumnSpan="2" Height="36" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="1" Text="显示名称" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="2" Text="工作目录" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="DirectoryBox" Grid.Row="2" Grid.Column="1" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" /><Button Grid.Row="2" Grid.Column="2" Content="浏览" Margin="8,12,0,0" Click="OnBrowseDirectory" />
            <TextBlock Grid.Row="3" Text="默认命令" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="CommandBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" ToolTip="例如 python -m uvicorn app.main:app" />
            <TextBlock Grid.Row="4" Text=".keyhub.json" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="ManifestBox" Grid.Row="4" Grid.Column="1" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" /><Button Grid.Row="4" Grid.Column="2" Content="读取清单" Margin="8,12,0,0" Click="OnBrowseManifest" />
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" Padding="18,8" Click="OnCancel" /><Button Content="保存项目" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="OnSave" /></StackPanel>
    </Grid>
</Window>
