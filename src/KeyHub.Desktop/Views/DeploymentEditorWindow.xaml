<Window x:Class="KeyHub.Desktop.Views.DeploymentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="部署配置" Width="640" Height="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource CanvasBrush}">
    <Grid Margin="26"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel><TextBlock x:Name="HeadingText" Text="新增部署配置" Style="{StaticResource PageTitle}" /><TextBlock Text="把项目映射后的变量写入服务器上的 .env 或 JSON 文件。" Style="{StaticResource PageSubtitle}" /></StackPanel>
        <Grid Grid.Row="1" Margin="0,22,0,18"><Grid.ColumnDefinitions><ColumnDefinition Width="140" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="名称" VerticalAlignment="Center" /><TextBox x:Name="NameBox" Grid.Column="1" Height="36" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="1" Text="服务器" Margin="0,16,0,0" VerticalAlignment="Center" /><ComboBox x:Name="ServerBox" Grid.Row="1" Grid.Column="1" Height="36" Margin="0,12,0,0" />
            <TextBlock Grid.Row="2" Text="项目" Margin="0,16,0,0" VerticalAlignment="Center" /><ComboBox x:Name="ProjectBox" Grid.Row="2" Grid.Column="1" Height="36" Margin="0,12,0,0" />
            <TextBlock Grid.Row="3" Text="目标文件" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="TargetPathBox" Grid.Row="3" Grid.Column="1" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="4" Text="格式" Margin="0,16,0,0" VerticalAlignment="Center" /><ComboBox x:Name="FormatBox" Grid.Row="4" Grid.Column="1" Height="36" Margin="0,12,0,0" />
            <TextBlock Grid.Row="5" Text="重启命令（可选）" Margin="0,16,0,0" VerticalAlignment="Center" /><StackPanel Grid.Row="5" Grid.Column="1" Margin="0,12,0,0"><TextBox x:Name="RestartBox" Height="36" VerticalContentAlignment="Center" /><TextBlock Text="Linux: systemctl restart 服务名；Windows: Restart-Service -Name 服务名" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" /></StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" Click="OnCancel" /><Button Content="保存部署" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="OnSave" /></StackPanel>
    </Grid>
</Window>
