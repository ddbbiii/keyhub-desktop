<Window x:Class="KeyHub.Desktop.Views.ServerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器" Width="610" Height="570" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource CanvasBrush}">
    <Grid Margin="26"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel><TextBlock x:Name="HeadingText" Text="新增服务器" Style="{StaticResource PageTitle}" /><TextBlock Text="支持密码或 SSH 私钥认证；首次测试后保存主机指纹。" Style="{StaticResource PageSubtitle}" /></StackPanel>
        <Grid Grid.Row="1" Margin="0,22,0,18"><Grid.ColumnDefinitions><ColumnDefinition Width="125" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <TextBlock Text="名称" VerticalAlignment="Center" /><TextBox x:Name="NameBox" Grid.Column="1" Height="36" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="1" Text="主机" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="HostBox" Grid.Row="1" Grid.Column="1" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="2" Text="端口" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="PortBox" Grid.Row="2" Grid.Column="1" Height="36" Margin="0,12,0,0" Text="22" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="3" Text="用户名" Margin="0,16,0,0" VerticalAlignment="Center" /><TextBox x:Name="UsernameBox" Grid.Row="3" Grid.Column="1" Height="36" Margin="0,12,0,0" VerticalContentAlignment="Center" />
            <TextBlock Grid.Row="4" Text="系统" Margin="0,16,0,0" VerticalAlignment="Center" /><ComboBox x:Name="OsBox" Grid.Row="4" Grid.Column="1" Height="36" Margin="0,12,0,0" />
            <TextBlock Grid.Row="5" Text="认证密钥" Margin="0,16,0,0" VerticalAlignment="Center" /><ComboBox x:Name="AuthenticationBox" Grid.Row="5" Grid.Column="1" Height="36" Margin="0,12,0,0" />
            <TextBlock Grid.Row="6" Text="备注" Margin="0,16,0,0" VerticalAlignment="Top" /><TextBox x:Name="NotesBox" Grid.Row="6" Grid.Column="1" Margin="0,12,0,0" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap" />
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" Click="OnCancel" /><Button Content="保存服务器" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="OnSave" /></StackPanel>
    </Grid>
</Window>
